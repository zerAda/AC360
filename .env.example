# Configuration d'environnement AC360 — copiez en ".env" et remplissez vos
# valeurs. ".env" est gitignoré : ne committez JAMAIS de secrets réels.
# En production, préférez Azure Key Vault / variables d'application.

# =========================================================================
# AUTHENTIFICATION ENTRA ID (OBLIGATOIRE pour l'API)
# =========================================================================
TENANT_ID=votre-tenant-id-entra
CLIENT_ID=votre-client-id-app
# Scopes/rôles exigés dans le token (séparés par des virgules). Optionnels.
REQUIRED_SCOPES=Audit.Trigger
REQUIRED_ROLES=
# Cache JWKS (secondes) : timeout de récupération et TTL avant rafraîchissement.
JWKS_TIMEOUT=10
JWKS_TTL_SECONDS=3600

# =========================================================================
# ON-BEHALF-OF (lecture SharePoint AU NOM de l'utilisateur — superposition RBAC)
# La passerelle échange le token utilisateur contre un token Graph délégué :
# l'audit ne peut lire QUE les documents auxquels l'utilisateur a accès.
# Prérequis tenant : permission Graph DÉLÉGUÉE Files.Read.All (ou Sites.Read.All)
# accordée + consentie sur l'app CLIENT_ID. OBO_CLIENT_ID défaut = CLIENT_ID.
# =========================================================================
OBO_CLIENT_ID=
OBO_CLIENT_SECRET=
# Mettre à true pour REFUSER l'audit si OBO n'est pas configuré (prod stricte) :
# sans OBO, le téléchargement retombe sur l'identité applicative (pas de RBAC user).
AC360_REQUIRE_OBO=false

# =========================================================================
# AZURE AI DOCUMENT INTELLIGENCE (OCR — Phase 3)
# Provisionnez la ressource puis renseignez endpoint + clé.
# =========================================================================
AZURE_OCR_ENDPOINT=https://votre-ressource.cognitiveservices.azure.com/
AZURE_OCR_KEY=votre_cle_secrete_ici

# =========================================================================
# MICROSOFT FABRIC
# =========================================================================
# Accès OneLake (Delta, pur Python — recommandé, pas d'ODBC). L'identité doit
# avoir un rôle (Viewer+) sur le workspace ET l'accès OneLake externe autorisé
# au niveau tenant Fabric.
FABRIC_WORKSPACE_ID=votre-workspace-id-fabric
FABRIC_GOLD_LAKEHOUSE_ID=votre-lakehouse-gold-id
FABRIC_CLIENT_TABLE=tbl_super_product_client_api_gold
# TTL du cache de référence en mémoire (secondes) : la table n'est lue qu'une
# fois par instance/TTL au lieu d'à chaque audit.
FABRIC_CACHE_TTL_SECONDS=3600

# (Legacy) Accès via SQL endpoint + ODBC — non utilisé par le backend OneLake.
FABRIC_SQL_ENDPOINT=xxxxxxx.datawarehouse.fabric.microsoft.com
FABRIC_DATABASE=NomDeVotreBaseArtus

# =========================================================================
# BACKEND AZURE DURABLE FUNCTIONS (passerelle api_server -> Function)
# =========================================================================
AZURE_FUNCTION_URL=http://localhost:7071/api
AZURE_FUNCTION_KEY=
# Clé système Durable (durabletask_extension) requise par les webhooks de
# gestion Durable (statut d'audit). DIFFÉRENTE de la clé de fonction. Si vide,
# fallback sur AZURE_FUNCTION_KEY (dev local).
AZURE_DURABLE_KEY=
# Task hub Durable (OBLIGATOIRE en prod : pas de valeur de test par défaut).
TASK_HUB_NAME=AC360Hub
# Drive SharePoint contenant les dossiers clients (téléchargement Graph).
SHAREPOINT_DRIVE_ID=

# =========================================================================
# STOCKAGE LOCAL DES JOBS / SORTIES
# =========================================================================
JOBS_BASE_DIR=jobs
# Extensions de documents autorisées (séparées par des virgules).
ALLOWED_EXTENSIONS=.pdf,.docx,.xlsx,.txt

# =========================================================================
# NOTIFICATIONS TEAMS (Phase 5)
# =========================================================================
TEAMS_WEBHOOK_URL=https://votre-tenant.webhook.office.com/webhookb2/...

# =========================================================================
# OBSERVABILITÉ (optionnel)
# =========================================================================
APPINSIGHTS_INSTRUMENTATIONKEY=

# =========================================================================
# GOUVERNANCE / KILL-SWITCH (P0-09) — aucune limite bloquante par défaut.
# Tout est ACTIVÉ tant qu'un admin ne met pas explicitement false / une liste.
# =========================================================================
AC360_GLOBAL_ENABLED=true
AC360_OCR_ENABLED=true
AC360_RAG_ENABLED=true
AC360_EMAIL_DRAFT_ENABLED=true
AC360_AUDIT_ENABLED=true
# Listes de blocage (CSV). Utilisateurs = hash SHA-256 (jamais d'UPN en clair).
AC360_BLOCKED_USERS_HASHED=
AC360_BLOCKED_TEAMS=
# Rôle Entra requis pour exécuter une action de contrôle admin.
AC360_ADMIN_ROLE=AC360.Admin

# =========================================================================
# USAGE TRACKING (P0-08)
# =========================================================================
AC360_ENVIRONMENT=dev
AC360_BOT_VERSION=0.0.0
# Sink JSONL optionnel ; en prod, brancher sur Application Insights / Log Analytics.
AC360_USAGE_SINK=

# =========================================================================
# FINOPS / COÛTS (P0-07) — aucun prix inventé : grille VIDE par défaut.
# Fournir la grille réelle via JSON, ex. {"ocr_document_intelligence":0.001}
# =========================================================================
AC360_RATE_CARD=
AC360_BUDGET_EUR=
AC360_BUDGET_WARN_PCT=80

# =========================================================================
# MICROSOFT PLANNER (relances) — IDs réels du plan/bucket cible.
# Sans ces valeurs, /api/planner/task renvoie 400 (échec clair, pas de POC).
# =========================================================================
PLANNER_DEFAULT_PLAN_ID=
PLANNER_DEFAULT_BUCKET_ID=
