# Fichier de configuration d'environnement pour l'Audit AC360
# Renommez ce fichier en ".env" et remplissez vos valeurs réelles.

# --- PHASE 3 : AZURE AI DOCUMENT INTELLIGENCE ---
# Ces valeurs sont générées par le script deploy_azure_ocr.ps1 ou trouvables sur votre portail Azure.
AZURE_OCR_ENDPOINT=https://votre-ressource.cognitiveservices.azure.com/
AZURE_OCR_KEY=votre_cle_secrete_ici

# --- PHASE 4 : MICROSOFT FABRIC (SQL ENDPOINT) ---
# Le point de terminaison SQL Analytics de votre Lakehouse/Data Warehouse Fabric
FABRIC_SQL_ENDPOINT=xxxxxxx.datawarehouse.fabric.microsoft.com
FABRIC_DATABASE=NomDeVotreBaseArtus

# --- PHASE 5 : TEAMS ---
# URL du Webhook de votre canal Teams
TEAMS_WEBHOOK_URL=https://votre-tenant.webhook.office.com/webhookb2/...
