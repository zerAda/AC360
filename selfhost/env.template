# =============================================================================
# AC360 — Stack IA privée (Onyx + Ollama) — gabarit d'environnement.
#
#   1. Copiez ce fichier en ".env"  :  cp env.template .env
#   2. Générez les secrets forts     :  ./scripts/gen-secrets.sh   (ou make secrets)
#   3. Démarrez                       :  make up
#
# ".env" est GITIGNORÉ : ne committez JAMAIS de secret réel.
# Les variables marquées (SECRET — généré) sont remplies par gen-secrets.sh.
# =============================================================================

# --- Versions épinglées (reproductibilité) ----------------------------------
IMAGE_TAG=4.1.1
OLLAMA_IMAGE_TAG=0.30.8

# --- Accès & authentification -----------------------------------------------
# Profil retenu : poste local. Onyx n'écoute que sur 127.0.0.1:${ONYX_HOST_PORT}.
ONYX_HOST_PORT=3000
WEB_DOMAIN=http://localhost:3000

# Authentification : disabled | basic | google_oauth | oidc | saml
# 'basic' = comptes locaux email/mot de passe. Le PREMIER compte créé est admin.
AUTH_TYPE=basic

# Durée de session (secondes) avant ré-authentification. Défaut : 24 h.
SESSION_EXPIRE_TIME_SECONDS=86400

# Restreindre l'énumération des comptes aux admins (durcissement). true recommandé.
USER_DIRECTORY_ADMIN_ONLY=true

# Vérification d'email pour l'auth 'basic'. Laisser false en local (pas de SMTP).
# Pour l'activer : REQUIRE_EMAIL_VERIFICATION=true + variables SMTP_* (cf. SECURITY.md).
REQUIRE_EMAIL_VERIFICATION=false

# Restreindre les domaines email autorisés (ex: gerep.fr). Vide = aucun filtre.
VALID_EMAIL_DOMAINS=

# Confidentialité : aucune télémétrie sortante.
DISABLE_TELEMETRY=true

# --- Secrets (générés par scripts/gen-secrets.sh — NE PAS committer) ---------
# Clé de chiffrement applicative Onyx.
SECRET=
# Postgres (compte applicatif + compte lecture seule).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
DB_READONLY_USER=db_readonly_user
DB_READONLY_PASSWORD=
# OpenSearch (mot de passe admin — doit respecter la complexité OpenSearch).
OPENSEARCH_ADMIN_PASSWORD=
# MinIO (stockage objet) + identifiants S3 utilisés par Onyx (mêmes valeurs).
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
S3_AWS_ACCESS_KEY_ID=
S3_AWS_SECRET_ACCESS_KEY=

# --- Ollama (LLM local) — `make tune` remplit ces valeurs au plus juste -------
# KEEP_ALIVE : durée de maintien en mémoire. 5m = libère la RAM à l'inactivité ;
#   -1 = toujours chargé (zéro latence). MAX_LOADED_MODELS / NUM_PARALLEL : coût RAM.
OLLAMA_KEEP_ALIVE=5m
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_QUEUE=512
# Perf (cf. docs/PERFORMANCE.md) : Flash Attention + cache KV quantifié q8_0
# → -30 à -50% de mémoire de contexte, quasi sans perte de qualité.
OLLAMA_FLASH_ATTENTION=1
OLLAMA_KV_CACHE_TYPE=q8_0
# Modèles à pré-tirer (séparés par des espaces). `make tune` choisit le plus
# gros modèle qui tient sur la machine. Défaut prudent ci-dessous.
#   <12 Go : "llama3.2:1b" · 16-24 Go : "llama3.2:3b" · 24 Go+/GPU : "qwen2.5:14b-instruct"
OLLAMA_MODELS_TO_PULL=llama3.2:3b nomic-embed-text

# --- Dimensionnement ressources (calibré ~16 Go RAM, CPU) -------------------
# Ajustez avec scripts/detect-hardware.sh. Voir docs/RUNBOOK.md.
OPENSEARCH_HEAP=1g
OPENSEARCH_MEM_LIMIT=2g
INFERENCE_MEM_LIMIT=4g
API_SERVER_MEM_LIMIT=3g
BACKGROUND_MEM_LIMIT=5g
WEB_MEM_LIMIT=1g
POSTGRES_MEM_LIMIT=1g
MINIO_MEM_LIMIT=512m
OLLAMA_MEM_LIMIT=6g
OLLAMA_CPU_LIMIT=4
NGINX_MEM_LIMIT=256m

# --- Avancé (laisser vide en local) -----------------------------------------
LOG_LEVEL=info
