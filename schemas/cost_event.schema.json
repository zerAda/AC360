{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ac360/schemas/cost_event.schema.json",
  "title": "AC360 Cost Event",
  "description": "Événement de coût estimé AC360. Les coûts ne sont JAMAIS présentés comme réels sans preuve : le champ cost_source qualifie chaque montant.",
  "type": "object",
  "required": ["event_id", "timestamp_utc", "cost_center", "estimated_cost_eur", "cost_source"],
  "additionalProperties": false,
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "timestamp_utc": { "type": "string", "format": "date-time" },
    "environment": { "type": "string", "enum": ["dev", "test", "uat", "prod", "staging"] },
    "cost_center": {
      "type": "string",
      "enum": [
        "copilot_studio_message",
        "copilot_studio_action",
        "ocr_document_intelligence",
        "fabric_onelake",
        "backend_api",
        "storage",
        "application_insights",
        "power_automate",
        "premium_connector"
      ]
    },
    "quantity": { "type": "number", "minimum": 0 },
    "unit": { "type": "string", "enum": ["message", "action", "page", "document", "gb", "request", "run"] },
    "unit_cost_eur": { "type": "number", "minimum": 0 },
    "estimated_cost_eur": { "type": "number", "minimum": 0 },
    "cost_source": { "type": "string", "enum": ["REEL_MESURE", "ESTIME", "PARAMETRABLE", "A_VALIDER"] },
    "commercial_id_hash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "team_id": { "type": ["string", "null"] },
    "client_id_hash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "use_case": { "type": ["string", "null"] }
  }
}
