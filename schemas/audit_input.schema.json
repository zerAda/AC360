{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ac360/schemas/audit_input.schema.json",
  "title": "AC360 Audit Input",
  "description": "Entrée normalisée du moteur d'audit : valeurs extraites du document + référence Fabric/Artus.",
  "type": "object",
  "required": ["document", "reference"],
  "additionalProperties": false,
  "properties": {
    "document": {
      "type": "object",
      "description": "Valeurs canoniques extraites du document client.",
      "required": ["nom_client"],
      "additionalProperties": true,
      "properties": {
        "nom_client": { "type": ["string", "null"] },
        "plafond_hospitalisation": { "type": ["string", "number", "null"] },
        "date_effet": { "type": ["string", "null"] },
        "numero_contrat": { "type": ["string", "null"] },
        "motif_operation": { "type": ["string", "null"] }
      }
    },
    "reference": {
      "type": "object",
      "description": "Données de gestion de référence (Fabric / Artus).",
      "required": ["nom_client"],
      "additionalProperties": true,
      "properties": {
        "client_id": { "type": ["string", "integer", "null"] },
        "nom_client": { "type": ["string", "null"] },
        "plafond_hospitalisation": { "type": ["string", "number", "null"] },
        "date_effet": { "type": ["string", "null"] },
        "numero_contrat": { "type": ["string", "null"] }
      }
    }
  }
}
